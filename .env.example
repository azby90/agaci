# ============================================
# AGACI — Variables d'environnement
# Copier ce fichier en .env.local pour le dev
# ============================================

# --- Next.js ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=remplacer-par-secret-aleatoire-32-chars

# --- Directus CMS ---
DIRECTUS_URL=http://localhost:8055
DIRECTUS_ADMIN_TOKEN=remplacer-par-token-admin-directus

# --- Base de données (pour scripts directs) ---
DATABASE_URL=postgresql://agaci:agaci_dev_password@localhost:5432/agaci_db

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@agaci.org
EMAIL_FROM_NAME=AGACI

# --- Stockage images (Cloudinary) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=votre-cloud-name
CLOUDINARY_API_KEY=xxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxx

# --- Paiements (CinetPay) ---
CINETPAY_API_KEY=xxxxxxxxxxxx
CINETPAY_SITE_ID=xxxxxxxxxxxx
CINETPAY_SECRET_KEY=xxxxxxxxxxxx
CINETPAY_NOTIFY_URL=https://votre-domaine.org/api/payments/webhook

# --- App publique ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AGACI
